{
  "name": "pockets",
  "source": "src/index.html",
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "type": "module",
  "scripts": {
    "start": "parcel",
    "build": "parcel build",
    "ohm": "ohm generateBundles --withTypes src/ohm/diceroll.ohm",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@ohm-js/cli": "^2.0.1",
    "@parcel/transformer-typescript-tsc": "^2.16.4",
    "parcel": "^2.16.4",
    "parcel-transformer-ts-css-modules": "^1.0.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@preact/signals": "^2.8.2",
    "ohm-js": "^17.5.0",
    "preact": "^10.29.0",
    "true-myth": "^7.1.0"
  },
  "alias": {
    "$": "./src",
    "lib": "./src/lib",
    "ohm": "./src/ohm",
    "react": "preact/compat",
    "react-dom": "preact/compat",
    "react-dom/test-utils": "preact/test-utils",
    "react/jsx-runtime": "preact/jsx-runtime"
  },
  "@parcel/transformer-css": {
    "cssModules": {
      "pattern": "pockets-[name]-[local]"
    }
  }
}
